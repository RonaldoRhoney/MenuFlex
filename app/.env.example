VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# URL da função serverless que cria a preference de pagamento no Mercado Pago
# (ver src/lib/payments.ts). Deixe vazio até essa função existir — o botão de
# upgrade de plano mostra um aviso em vez de quebrar.
VITE_CHECKOUT_API_URL=

# Número de WhatsApp (só dígitos, com código do país) da RhoneyInc pra receber
# indicações de parceiros (ver src/pages/Parceiros.tsx) quando o banco não está
# configurado. Opcional — sem ele, a página usa só o fallback por e-mail.
VITE_REFERRAL_WHATSAPP=
